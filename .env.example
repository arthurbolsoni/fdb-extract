# CDC integration test environment
# Source this before running: Get-Content .env | ForEach-Object { $k,$v=$_ -split '=',2; if($k -and !$k.StartsWith('#')){ [System.Environment]::SetEnvironmentVariable($k.Trim(),$v.Trim()) } }
# Or in PowerShell: $env:TEST_PG_PASS="mypass"; etc.

# Firebird server: localhost:3050, SYSDBA/masterkey (hardcoded in test)
# Optional: override fbclient.dll path (auto-detected if omitted)
#FBCLIENT_PATH=C:\Firebird-5\fbclient.dll

# Dir where Firebird server will create the test .fdb file
# Must be writable by the Firebird service (e.g. LocalSystem)
TEST_FDB_DIR=C:\Temp

# PostgreSQL connection
TEST_PG_HOST=localhost
TEST_PG_PORT=5432
TEST_PG_USER=postgres
TEST_PG_PASS=postgres
TEST_PG_DB=replica_firebird
